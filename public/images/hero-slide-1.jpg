<svg viewBox="0 0 1920 1080" fill="none" xmlns="http://www.w3.org/2000/svg">
  <!-- Gradient background -->
  <defs>
    <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#2D5A27;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#1A3A1A;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#0F2410;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="1920" height="1080" fill="url(#grad1)"/>
  
  <!-- Abstract journal pages pattern -->
  <g opacity="0.2">
    <rect x="200" y="150" width="600" height="800" fill="#C8DEC8" opacity="0.1" rx="8"/>
    <rect x="220" y="170" width="560" height="760" fill="white" opacity="0.05"/>
    <line x1="250" y1="220" x2="750" y2="220" stroke="#C8DEC8" stroke-width="2" opacity="0.2"/>
    <line x1="250" y1="280" x2="750" y2="280" stroke="#C8DEC8" stroke-width="2" opacity="0.2"/>
    <line x1="250" y1="340" x2="750" y2="340" stroke="#C8DEC8" stroke-width="2" opacity="0.2"/>
  </g>
  
  <!-- Decorative circles -->
  <circle cx="1400" cy="300" r="200" fill="#C084C8" opacity="0.15"/>
  <circle cx="1500" cy="400" r="150" fill="#6DC56D" opacity="0.1"/>
  
  <!-- Text suggestion -->
  <text x="960" y="540" font-size="120" font-weight="700" font-family="'Poltawski Nowy', serif" fill="white" text-anchor="middle" opacity="0.3">FALL FORWARD</text>
</svg>