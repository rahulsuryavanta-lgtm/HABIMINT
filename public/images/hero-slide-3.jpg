<svg viewBox="0 0 1920 1080" fill="none" xmlns="http://www.w3.org/2000/svg">
  <!-- Gradient background -->
  <defs>
    <linearGradient id="grad3" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#6DC56D;stop-opacity:0.3" />
      <stop offset="50%" style="stop-color:#2D5A27;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#0F2410;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="1920" height="1080" fill="url(#grad3)"/>
  
  <!-- Grid pattern -->
  <g opacity="0.15">
    <line x1="400" y1="0" x2="400" y2="1080" stroke="#C8DEC8" stroke-width="1"/>
    <line x1="800" y1="0" x2="800" y2="1080" stroke="#C8DEC8" stroke-width="1"/>
    <line x1="1200" y1="0" x2="1200" y2="1080" stroke="#C8DEC8" stroke-width="1"/>
    <line x1="1600" y1="0" x2="1600" y2="1080" stroke="#C8DEC8" stroke-width="1"/>
    <line x1="0" y1="270" x2="1920" y2="270" stroke="#C8DEC8" stroke-width="1"/>
    <line x1="0" y1="540" x2="1920" y2="540" stroke="#C8DEC8" stroke-width="1"/>
    <line x1="0" y1="810" x2="1920" y2="810" stroke="#C8DEC8" stroke-width="1"/>
  </g>
  
  <!-- Number 21 -->
  <text x="300" y="600" font-size="400" font-weight="900" font-family="'Poltawski Nowy', serif" fill="#C084C8" opacity="0.2">21</text>
  
  <!-- Decorative elements -->
  <circle cx="1600" cy="200" r="100" fill="#6DC56D" opacity="0.3"/>
  <rect x="200" y="800" width="300" height="200" fill="#C084C8" opacity="0.15" rx="10"/>
  
  <!-- Text suggestion -->
  <text x="960" y="540" font-size="100" font-weight="700" font-family="'Poltawski Nowy', serif" fill="white" text-anchor="middle" opacity="0.3">VERSION 2.0</text>
</svg>